# =============================================================================
# Kinova Production Environment Variables Template (.env.prod.example)
# Copy this file to .env on the production VPS and update the values.
# =============================================================================

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
APP_NAME=Kinova
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:PLACEHOLDER_GENERATED_BY_KEY_GENERATE
APP_URL=https://api.alezonyth.my.id
FRONTEND_URL=https://kinova.alezonyth.my.id
CORS_ALLOWED_ORIGINS=https://kinova.alezonyth.my.id # Cloudflare Pages domain (CORS)

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL 16)
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=kinova_production
DB_USERNAME=kinova_db_user
DB_PASSWORD=YOUR_SECURE_RANDOM_DB_PASSWORD

# -----------------------------------------------------------------------------
# Redis Configuration (Redis 7)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_SECURE_RANDOM_REDIS_PASSWORD

# -----------------------------------------------------------------------------
# Queue Configuration
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=redis

# -----------------------------------------------------------------------------
# Broadcast Configuration
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=reverb

# -----------------------------------------------------------------------------
# Reverb WebSocket Configuration
# -----------------------------------------------------------------------------
REVERB_APP_ID=kinova_prod_app_id
REVERB_APP_KEY=kinova_prod_app_key
REVERB_APP_SECRET=kinova_prod_app_secret
REVERB_HOST=ws.alezonyth.my.id
REVERB_PORT=8080
REVERB_SCHEME=https

# -----------------------------------------------------------------------------
# Additional Laravel Production Optimization Settings
# -----------------------------------------------------------------------------
PHP_CLI_SERVER_WORKERS=4
